        "name": "platform",
        "in": "query",
        "required": true,
        "schema": { "type": "string" }
      },
      "rcAccessToken": {
        "name": "rcAccessToken",
        "in": "query",
        "required": true,
        "schema": { "type": "string" },
        "description": "RingCentral access token used for admin validation."
      },
      "phoneNumber": {
        "name": "phoneNumber",
        "in": "query",
        "required": true,
        "schema": { "type": "string" },
        "description": "Phone number to search, normally E.164."
      },
      "appointmentId": {
        "name": "appointmentId",
        "in": "path",
        "required": true,
        "schema": { "type": "string" }
      },
      "id": {
        "name": "id",
        "in": "path",
        "required": true,
        "schema": { "type": "string" }
      }
    },
    "requestBodies": {
      "GenericJson": {
        "required": false,
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "additionalProperties": true
            }
          }
        }
      }
    },
    "responses": {
      "OkJson": {
        "description": "Successful JSON response. Exact response shape depends on the route and connector interface.",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "additionalProperties": true
            }
          }
        }
      },
      "BadRequest": {
        "description": "Bad request or connector error.",
        "content": {
          "application/json": {
            "schema": {
              "oneOf": [
                {
                  "type": "object",
                  "additionalProperties": true
                },
                {
                  "type": "string"
                }
              ]
            }
          }
        }
      },
      "Forbidden": {
        "description": "Admin validation failed."
      }
    }
  }
