{
  "openapi": "3.1.0",
  "info": {
    "title": "App Connect CRM Server",
    "version": "1.7.30",
    "description": "Route inventory for the current Express server. The runtime source of truth is packages/core/index.js plus app-specific routes in src/index.js."
  },
  "servers": [
    {
      "url": "http://localhost:6066",
      "description": "Local development server"
    },
    {
      "url": "https://{host}",
      "description": "Deployed connector server",
      "variables": {
        "host": {
          "default": "example.com"
        }
      }
    }
  ],
  "tags": [
    { "name": "Health" },
    { "name": "Manifest" },
    { "name": "Auth" },
    { "name": "Admin" },
    { "name": "User" },
    { "name": "Contacts" },
    { "name": "Appointments" },
    { "name": "Call Logs" },
    { "name": "Message Logs" },
    { "name": "Call Down" },
    { "name": "Plugins" },
    { "name": "MCP" },
    { "name": "RingCentral Reports" },
    { "name": "Google Integrations" },
    { "name": "Pipedrive" }
  ],
  "paths": {
    "/isAlive": {
      "get": {
        "tags": ["Health"],
        "summary": "Health check",
        "operationId": "getIsAlive",
        "responses": {
          "200": {
            "description": "Returns OK as text/plain."
          }
        }
      }
    },
    "/implementedInterfaces": {
      "get": {
        "tags": ["Manifest"],
        "summary": "List implemented connector methods for a platform",
        "operationId": "getImplementedInterfaces",
        "parameters": [
          { "$ref": "#/components/parameters/platform" }
        ],
        "responses": {
          "200": { "$ref": "#/components/responses/OkJson" },
          "400": { "$ref": "#/components/responses/BadRequest" }
        }
      }
    },
    "/crmManifest": {
      "get": {
        "tags": ["Manifest"],
        "summary": "Return a platform manifest",
        "description": "Kept for backward compatibility with older clients.",
        "operationId": "getCrmManifest",
        "parameters": [
          {
            "name": "platformName",
            "in": "query",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": { "$ref": "#/components/responses/OkJson" },
          "400": { "$ref": "#/components/responses/BadRequest" }
        }
      }
    },
    "/releaseNotes": {
      "get": {
        "tags": ["Manifest"],
        "summary": "Return merged global and connector release notes",
        "operationId": "getReleaseNotes",
        "responses": {
          "200": { "$ref": "#/components/responses/OkJson" }
        }
      }
    },
