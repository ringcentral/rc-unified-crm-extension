{
  "name": "rc-unified-crm-extension-server",
  "version": "1.7.37",
  "description": "RingCentral App Connect",
  "main": ".ts-build/src/index.js",
  "types": ".ts-build/src/index.d.ts",
  "private": true,
  "workspaces": [
    "./packages/*"
  ],
  "scripts": {
    "ngrok": "ngrok http 6066 ",
    "tunnel": "lite-http-tunnel start 6066 -p crm",
    "server": "npm run build:ts && nodemon",
    "start": "npm run server",
    "start-debug": "npm run build:ts && node --inspect ./.ts-build/src/server.js",
    "test": "npm run build:ts && node ./.ts-build/scripts/run-tests.js",
    "test:root": "npm run build:ts && npm run test:root:raw",
    "test:root:raw": "set NODE_ENV=test&&jest --config ./.ts-build/jest.config.js --forceExit -i",
    "test:e2e": "npm run build:ts && set NODE_ENV=test&&jest --config ./.ts-build/jest.e2e.config.js --runInBand",
    "test-coverage": "npm run build:ts && node ./.ts-build/scripts/run-coverage.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typecheck:core": "tsc -p packages/core/tsconfig.json --noEmit",
    "clean:ts": "node -e \"require('fs').rmSync('.ts-build',{recursive:true,force:true})\"",
    "build:ts": "npm run clean:ts && tsc -p tsconfig.build.json && node ./.ts-build/scripts/copy-ts-assets.js",
    "build-local": "npm run build:ts && node ./.ts-build/scripts/build.js",
    "build": "npm run build:ts && node ./.ts-build/scripts/serverless-build.js",
    "deploy": "npm run build:ts && node ./.ts-build/scripts/serverless-deploy.js",
    "build-test": "npm run build:ts && node ./.ts-build/scripts/serverless-build-test.js",
    "deploy-test": "npm run build:ts && node ./.ts-build/scripts/serverless-deploy-test.js",
    "build-test-beta": "npm run build:ts && node ./.ts-build/scripts/serverless-build-test-beta.js",
    "deploy-test-beta": "npm run build:ts && node ./.ts-build/scripts/serverless-deploy-test-beta.js",
    "dynamo-local": "npm run build:ts && node ./.ts-build/scripts/dynamo-local.js",
    "dynamo-admin": "dynamodb-admin --port 8001",
    "htt": "npm run build:ts && node ./.ts-build/tests/highTrafficTestRun.js",
    "update": "npm run build:ts && node ./.ts-build/scripts/updateVersion.js",
    "s3-local": "minio.exe server ./data --address \":9001\" --console-address \":9002\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ringcentral/rc-unified-crm-extension.git"
  },
  "keywords": [
    "RingCentral",
    "crm",
    "chrome",
    "extension"
  ],
  "author": "Da Kong",
  "license": "MIT",
  "dependencies": {
    "awesome-phonenumber": "^5.6.0",
    "axios": "^1.12.2",
    "dotenv": "^16.0.3",
    "express": "^4.22.1",
    "googleapis": "^148.0.0",
    "moment": "^2.29.4",
    "moment-timezone": "^0.5.39",
    "pg": "^8.8.0",
    "sequelize": "^6.29.0",
    "serverless-http": "^3.0.3",
    "shortid": "^2.2.17"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@octokit/rest": "^19.0.5",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.19.0",
    "commander": "^9.4.1",
    "dynamodb-admin": "^5.1.3",
    "dynamodb-local": "^0.0.36",
    "eslint": "^9.22.0",
    "globals": "^16.0.0",
    "inquirer": "^9.1.4",
    "jest": "^29.3.1",
    "ngrok": "^5.0.0-beta.2",
    "nock": "^13.2.9",
    "nodemon": "^3.1.3",
    "serverless": "^3.23.0",
    "serverless-deployment-bucket": "^1.6.0",
    "serverless-plugin-log-retention": "^2.1.0",
    "shelljs": "^0.8.5",
    "simple-git": "^3.14.1",
    "sqlite3": "^5.1.7",
    "supertest": "^6.3.1",
    "typescript": "^5.6.3"
  },
  "overrides": {
    "js-object-utilities": "2.2.1"
  },
  "bugs": {
    "url": "https://github.com/ringcentral/rc-unified-crm-extension/issues"
  },
  "homepage": "https://github.com/ringcentral/rc-unified-crm-extension#readme"
}
