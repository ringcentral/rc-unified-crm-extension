{
  "name": "@app-connect/cli",
  "version": "0.1.5",
  "description": "CLI for RingCentral App Connect",
  "main": "./dist/bin/appconnect.js",
  "bin": {
    "appconnect": "./dist/bin/appconnect.js"
  },
  "files": [
