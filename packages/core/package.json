{
  "name": "@app-connect/core",
  "version": "1.7.38",
  "description": "RingCentral App Connect Core",
  "main": "dist/index.js",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json",
    "./types": {
      "types": "./dist/types/index.d.ts"
    },
    "./types/*": {
      "types": "./dist/types/*.d.ts"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "require": "./dist/*.js",
      "default": "./dist/*.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ringcentral/rc-unified-crm-extension.git"
  },
  "keywords": [
    "RingCentral",
    "App Connect"
  ],
  "files": [
    "dist",
    "README.md",
    "releaseNotes.json"
  ],
  "author": "RingCentral Labs",
  "license": "MIT",
  "peerDependencies": {
    "axios": "^1.12.2",
    "express": "^4.22.1",
    "moment": "^2.29.4",
    "moment-timezone": "^0.5.39",
    "pg": "^8.8.0",
    "sequelize": "^6.29.0"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.751.0",
    "@aws-sdk/client-s3": "^3.1086.0",
    "@aws-sdk/s3-request-presigner": "^3.1086.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/express": "^4.17.25",
    "awesome-phonenumber": "^5.6.0",
    "body-parser": "^1.20.4",
    "body-parser-xml": "^2.0.5",
    "client-oauth2": "^4.3.3",
    "cors": "^2.8.5",
    "country-state-city": "^3.2.1",
    "dotenv": "^16.0.3",
    "dynamoose": "^4.0.3",
    "jsonwebtoken": "^9.0.0",
    "mixpanel": "^0.18.0",
    "shortid": "^2.2.17",
    "tz-lookup": "^6.1.25",
    "ua-parser-js": "^1.0.38",
    "zod": "^4.4.3"
  },
  "scripts": {
    "test": "cd ../.. && npm run build:ts && cd packages/core && npm run test:raw",
    "test:raw": "jest --config ../../.ts-build/packages/core/jest.config.js",
    "test:watch": "cd ../.. && npm run build:ts && cd packages/core && jest --config ../../.ts-build/packages/core/jest.config.js --watch",
    "test:coverage": "cd ../.. && npm run build:ts && cd packages/core && jest --config ../../.ts-build/packages/core/jest.config.js --coverage",
    "test:ci": "cd ../.. && npm run build:ts && cd packages/core && jest --config ../../.ts-build/packages/core/jest.config.js --ci --coverage --watchAll=false",
    "prepack": "cd ../.. && npm run build:ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "axios": "^1.12.2",
    "eslint": "^9.22.0",
    "express": "^4.22.1",
    "globals": "^16.0.0",
    "jest": "^29.3.1",
    "moment": "^2.29.4",
    "moment-timezone": "^0.5.39",
    "nock": "^13.2.9",
    "pg": "^8.8.0",
    "sequelize": "^6.29.0",
    "sqlite3": "^5.1.2",
    "supertest": "^6.3.1"
  },
  "overrides": {
    "js-object-utilities": "2.2.1"
  },
  "bugs": {
    "url": "https://github.com/ringcentral/rc-unified-crm-extension/issues"
  },
  "homepage": "https://github.com/ringcentral/rc-unified-crm-extension#readme"
}
