APP_HOST=localhost
PORT=6066

# Example plugin route ids used by src/app.js
SYNC_PLUGIN_ID=sync-all-caps
ASYNC_PLUGIN_ID=async-all-caps

# Plugin user-settings key generated from the developer portal.
# Replace this with your actual plugin setting key.
PLUGIN_SETTING_KEY=plugin_replace_with_your_plugin_setting_key

# Optional examples used in the commented OAuth/license snippets.
PLUGIN_OAUTH_AUTHORIZE_URL=
PLUGIN_LICENSE_TIER=Basic
