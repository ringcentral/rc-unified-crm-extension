APP_HOST=localhost
PORT=6066
APP_SERVER=
APP_SERVER_SECRET_KEY=

# We use sqlite for local development. Postgres is recommended for prod
DATABASE_URL=sqlite://./db.sqlite
IS_PROD=false

# DYNAMODB is used for refresh token lock
DYNAMODB_LOCALHOST=http://localhost:8000 # use local dynamodb server for dev
DYNAMODB_TABLE_PREFIX=

# MY CRM
MY_CRM_CLIENT_ID=
MY_CRM_CLIENT_SECRET=
MY_CRM_TOKEN_URI=
MY_CRM_REDIRECT_URI=https://ringcentral.github.io/ringcentral-embeddable/redirect.html

# Admin

ADMIN_EXTENSION_ID_DEV_PASS_LIST=1234567890

# You'll need to create a RingCentral app on https://developer.ringcentral.com/ to get the client id and secret.
# Scopes: Analytics, Read Accounts, Read Call Log, Read Messages
RINGCENTRAL_SERVER=https://platform.ringcentral.com
RINGCENTRAL_CLIENT_ID=
RINGCENTRAL_CLIENT_SECRET=