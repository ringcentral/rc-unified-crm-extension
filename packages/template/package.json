{
  "name": "@app-connect/template",
  "version": "1.7.37",
  "description": "Template project for RingCentral App Connect",
  "main": "dist/src/server.ts",
  "private": true,
  "scripts": {
    "start": "npm run prod",
    "prod": "npm run build:ts && node dist/src/server.ts",
    "dev": "nodemon --watch src --ext ts,json --exec \"npm run prod\"",
    "test": "npm run build:ts && jest --config dist/jest.config.js",
    "test:coverage": "npm run build:ts && jest --config dist/jest.config.js --coverage",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "build:ts": "npm run clean && tsc -p tsconfig.build.json && node ./dist/scripts/copy-assets.js",
    "build": "npm run build:ts && node ./dist/scripts/serverless-build.js",
    "deploy": "npm run build && node ./dist/scripts/serverless-deploy.js"
  },
  "dependencies": {
    "@app-connect/core": "^1.7.37",
    "axios": "^1.12.2",
    "dotenv": "^16.0.3",
    "express": "^4.22.1",
    "moment": "^2.29.4",
    "moment-timezone": "^0.5.39",
    "pg": "^8.8.0",
    "sequelize": "^6.29.0",
    "serverless-http": "^3.0.3",
    "shortid": "^2.2.17",
    "awesome-phonenumber": "^5.6.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.19.0",
    "dynamodb-local": "^0.0.36",
    "eslint": "^9.22.0",
    "globals": "^16.0.0",
    "jest": "^29.3.1",
    "ngrok": "^5.0.0-beta.2",
    "nock": "^13.2.9",
    "nodemon": "^3.1.3",
    "serverless": "^3.23.0",
    "serverless-deployment-bucket": "^1.6.0",
    "serverless-plugin-log-retention": "^2.1.0",
    "shelljs": "^0.8.5",
    "simple-git": "^3.14.1",
    "sqlite3": "^5.1.5",
    "supertest": "^6.3.1",
    "typescript": "^5.6.3"
  },
  "keywords": [
    "ringcentral",
    "app-connect",
    "crm",
    "template"
  ],
  "author": "Developer name",
  "license": "ISC"
}
