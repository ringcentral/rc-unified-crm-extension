{
    "serverUrl": "https://xxxx.ngrok.app",
    "redirectUri": "https://ringcentral.github.io/ringcentral-embeddable/redirect.html",
    "author": {
        "name": "Test Developer",
        "websiteUrl": ""
    },
    "platforms": {
        "testCRM": {
            "logoUrl": "https://avatars.githubusercontent.com/u/6549285?s=200&v=4",
            "documentationUrl": "https://ringcentral.github.io/rc-unified-crm-extension",
            "releaseNotesUrl": "https://ringcentral.github.io/rc-unified-crm-extension/release-notes/",
            "getSupportUrl": "https://community.ringcentral.com/topic/new?fid=22",
            "writeReviewUrl": "https://chromewebstore.google.com/detail/ringcentral-crm-extension/kkhkjhafgdlihndcbnebljipgkandkhh/reviews",
            "urlIdentifier": "*.labs.ringcentral.com/*",
            "name": "testCRM",
            "displayName": "Test CRM",
            "enableExtensionNumberLoggingSetting": true,
            "requestConfig": {
                "timeout": 30
            },
            "auth": {
                "type": "apiKey",
                "apiKey": {
                    "page": {
                        "title": "test CRM",
                        "content": [
                            {
                                "const": "apiKey",
                                "title": "apiKey",
                                "type": "string",
                                "required": true
                            }
                        ]
                    }
                },
                "oauth": {
                    "authUrl": "",
                    "clientId": "",
                    "redirectUri": "https://ringcentral.github.io/ringcentral-embeddable/redirect.html",
                    "customState": "",
                    "scope": ""
                }
            },
            "canOpenLogPage": false,
            "contactTypes": [
                {
                    "display": "TestContactType",
                    "value": "testContact"
                },
                {
                    "display": "Contact",
                    "value": "cta"
                }
            ],
            "embeddedOnCrmPage": {
                "welcomePage": {
                    "docLink": "https://ringcentral.github.io/rc-unified-crm-extension/",
                    "videoLink": "https://youtu.be/pQgdsAR1UCI"
                }
            },
            "page": {
                "callLog": {
                    "additionalFields": [
                        {
                            "const": "associatedDeal",
                            "title": "Deals",
                            "type": "selection",
                            "contactDependent": true
                        },
                        {
                            "const": "state",
                            "title": "State",
                            "type": "selection",
                            "contactDependent": false,
                            "allowCustomValue": true,
                            "defaultSettingId": "testDefaultState",
                            "defaultSettingValues": {
                                "inboundCall": {
                                    "settingId": "testInboundCallState"
                                },
                                "outboundCall": {
                                    "settingId": "testOutboundCallState"
                                }
                            }
                        },
                        {
                            "const": "type",
                            "title": "Type",
                            "type": "selection",
                            "contactDependent": false,
                            "allowCustomValue": true,
                            "defaultSettingId": "testDefaultType",
                            "defaultSettingValues": {
                                "inboundCall": {
                                    "settingId": "testInboundCallType"
                                },
                                "outboundCall": {
                                    "settingId": "testOutboundCallType"
                                }
                            }
                        }
                    ]
                },
                "messageLog": {
                    "additionalFields": [
                        {
                            "const": "associatedDeal",
                            "title": "Deals",
                            "type": "selection",
                            "contactDependent": true
                        },
                        {
                            "const": "state",
                            "title": "State",
                            "type": "inputField",
                            "contactDependent": false,
                            "allowCustomValue": true,
                            "defaultSettingId": "testDefaultState",
                            "defaultSettingValues": {
                                "message": {
                                    "settingId": "testMessageState"
                                },
                                "outboundCall": {
                                    "voicemail": "testVoicemailState"
                                }
                            }
                        },
                        {
                            "const": "type",
                            "title": "Type",
                            "type": "inputField",
                            "contactDependent": false,
                            "allowCustomValue": true,
                            "defaultSettingId": "testDefaultType",
                            "defaultSettingValues": {
                                "inboundCall": {
                                    "settingId": "testMessageState"
                                },
                                "outboundCall": {
                                    "settingId": "testVoicemailState"
                                }
                            }
                        }
                    ]
                }
            },
            "settings":[
                {
                    "id": "testDefaultState",
                    "type": "section",
                    "name": "Test default state",
                    "items": [
                        {
                            "id": "stateMatchWarning",
                            "name": "Info: state matching warning",
                            "type": "warning",
                            "value": "State value match ignores cases and spaces"
                        },
                        {
                            "id": "testInboundCallState",
                            "type": "inputField",
                            "name": "Default state for inbound calls",
                            "placeholder": "Enter state value"
                        },
                        {
                            "id": "testOutboundCallState",
                            "type": "inputField",
                            "name": "Default state for outbound calls",
                            "placeholder": "Enter state value"
                        },
                        {
                            "id": "testMessageState",
                            "type": "inputField",
                            "name": "Default state for SMS",
                            "placeholder": "Enter state value"
                        },
                        {
                            "id": "testVoicemailState",
                            "type": "inputField",
                            "name": "Default state for voicemails",
                            "placeholder": "Enter state value"
                        }
                    ]
                },
                {
                    "id": "testDefaultType",
                    "type": "section",
                    "name": "Test default type",
                    "items": [
                        {
                            "id": "typeMatchWarning",
                            "name": "Info: type matching warning",
                            "type": "warning",
                            "value": "Type value match ignores cases and spaces"
                        },
                        {
                            "id": "testInboundCallType",
                            "type": "inputField",
                            "name": "Default type for inbound calls",
                            "placeholder": "Enter type value"
                        },
                        {
                            "id": "testOutboundCallType",
                            "type": "inputField",
                            "name": "Default type for outbound calls",
                            "placeholder": "Enter type value"
                        },
                        {
                            "id": "testMessageType",
                            "type": "inputField",
                            "name": "Default type for SMS",
                            "placeholder": "Enter type value"
                        },
                        {
                            "id": "testVoicemailType",
                            "type": "inputField",
                            "name": "Default type for voicemails",
                            "placeholder": "Enter type value"
                        }
                    ]
                }
            ]
        }
    },
    "version": "1.2.0"
}