{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": ".ts-build",
    "noEmit": false,
    "declaration": true,
    "declarationMap": false,
    "sourceMap": false
  },
  "include": [
    "src/**/*.ts",
    "packages/core/**/*.ts",
    "scripts/**/*.ts",
    "tests/**/*.ts",
    "jest.config.ts",
    "jest.e2e.config.ts"
  ],
  "exclude": [
    "node_modules",
    "coverage",
    "build",
    "serverless-deploy",
    "serverless-deploy-test",
    "serverless-deploy-test-beta",
    ".ts-build",
    "packages/core/test",
    "packages/core/mcp/ui",
    "packages/**/node_modules"
  ]
}
